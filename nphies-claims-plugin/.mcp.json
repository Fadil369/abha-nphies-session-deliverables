{
  "mcpServers": {
    "oracle-portal": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/../mcp-oracle-db/src/index.js"],
      "env": {
        "PORTAL_USER": "${PORTAL_USER}",
        "PORTAL_PASS": "${PORTAL_PASS}",
        "ABHA_USER":    "${ABHA_USER}",
        "ABHA_PASS":    "${ABHA_PASS}",
        "RIYADH_USER":  "${RIYADH_USER}",
        "RIYADH_PASS":  "${RIYADH_PASS}",
        "MADINAH_USER": "${MADINAH_USER}",
        "MADINAH_PASS": "${MADINAH_PASS}",
        "UNAIZAH_USER": "${UNAIZAH_USER}",
        "UNAIZAH_PASS": "${UNAIZAH_PASS}",
        "KHAMIS_USER":  "${KHAMIS_USER}",
        "KHAMIS_PASS":  "${KHAMIS_PASS}",
        "JIZAN_USER":   "${JIZAN_USER}",
        "JIZAN_PASS":   "${JIZAN_PASS}",
        "ORACLE_PROFILE_DIR": "${ORACLE_PROFILE_DIR}",
        "CHROME_PATH": "${CHROME_PATH}",
        "HEADLESS": "true",
        "NODE_ENV": "production"
      },
      "cwd": "${CLAUDE_PLUGIN_ROOT}/..",
      "autoStart": true,
      "alwaysAllow": true
    }
  }
}
